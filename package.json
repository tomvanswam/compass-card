{
  "name": "compass-card",
  "version": "2.0.0'",
  "description": "Lovelace compass-card",
  "keywords": [
    "home-assistant",
    "homeassistant",
    "hass",
    "automation",
    "lovelace",
    "custom-cards"
  ],
  "source": "src/index.ts",
  "module": "dist/compass-card.js",
  "main": "src/index.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomvanswam/compass-card.git"
  },
  "author": "Tom van Swam <tom@vanswam.com>",
  "license": "MIT",
  "targets": {
    "module": {
      "includeNodeModules": true
    }
  },
  "scripts": {
    "start": "rollup -c --watch --bundleConfigAsCjs",
    "build": "rollup -c --bundleConfigAsCjs",
    "format": "prettier --write .",
    "start:hass-stable": "podman run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:stable",
    "start:hass": "podman run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:beta",
    "start:hass-dev": "podman run --rm -p8123:8123 -v ./.hass_dev:/config homeassistant/home-assistant:dev"
  },
  "dependencies": {
    "@material/mwc-select": "^0.27.0",
    "@material/mwc-textfield": "^0.27.0",
    "color": "^4.2.3",
    "custom-card-helpers": "^1.9.0",
    "hammerjs": "^2.0.8",
    "home-assistant-js-websocket": "^9.4.0",
    "lit": "^3.2.1",
    "memoize-one": "^6.0.0",
    "sortablejs": "^1.15.3",
    "superstruct": "^2.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@material/mwc-ripple": "^0.27.0",
    "@material/tab-bar": "^14.0.0",
    "@rollup/plugin-babel": "^6.0.4",
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.1",
    "@types/color": "^4.2.0",
    "@types/hammerjs": "^2.0.46",
    "eslint": "^9.14.0",
    "prettier": "^3.3.3",
    "rollup": "^4.18.0",
    "rollup-plugin-serve": "^1.1.1",
    "typescript": "^5.6.3"
  }
}
